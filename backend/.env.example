# Clave secreta para firmar los JWT.
# Generá una segura con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia_esto_por_una_clave_segura

# Duración de los tokens de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración de los refresh tokens (en días)
REFRESH_TOKEN_EXPIRE_DAYS=7

# URL de conexión a la base de datos.
# SQLite local: sqlite:///./concejo_escolar.db
# SQLite en Docker: sqlite:////app/data/concejo_escolar.db
DATABASE_URL=sqlite:///./concejo_escolar.db

# Credenciales del usuario administrador creado en el seed inicial
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia_esto_en_produccion

# Orígenes permitidos para CORS (separados por coma, sin espacios).
# Incluí todos los dominios/IPs desde donde accede el frontend.
# Ej. producción: http://92.113.39.212:3005,http://92.113.39.212:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3005
